// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "diff_view_style": "split",
  "cli_default_open_behavior": "new_window",
  "agent_servers": {
    "opencode": {
      "type": "registry",
    },
    "amp-acp": {
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
    "gemini": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
    "tree_view": true,
  },
  "sticky_scroll": {
    "enabled": true,
  },
  "base_keymap": "VSCode",
  "redact_private_values": true,
  "ui_font_size": 14,
  "buffer_font_size": 13,
  "agent_ui_font_size": 14,
  "agent_buffer_font_size": 13,
  "pane_split_direction_vertical": "right",
  "scrollbar": {
    "show": "never",
  },
  "tab_bar": {
    "show": true,
  },
  "agent": {
    "tool_permissions": {
      "default": "allow",
    },
    "dock": "right",
    "use_modifier_to_send": true,
    "default_profile": "write",
    "model_parameters": [],
  },
  "auto_update_extensions": {
    "go-snippets": false,
  },
  "project_panel": {
    "dock": "left",
    "hide_gitignore": false,
  },
  "edit_predictions": {
    "provider": "copilot",
    "mode": "eager",
    "enabled_in_text_threads": false,
  },
  "terminal": {
    "dock": "right",
    "shell": {
      "with_arguments": {
        "program": "/opt/homebrew/bin/fish", // or path to your preferred shell
        // "args": ["-l", "-c", "tmux new-session -A -s \"$(basename \"$PWD\")\""],
        "args": [
          "-l",
          "-c",
          "tmux new-session -A -s \"$(string join '/' (basename (dirname (pwd))) (basename (pwd)))\"",
        ],
      },
    },
    "copy_on_select": true,
    "cursor_shape": "bar",
  },
  "search": {
    "regex": true,
  },
  "theme": "Ayu Dark",
  "vim_mode": true,
  "command_aliases": {
    "crp": "workspace::CopyRelativePath",
    "cpp": "workspace::CopyPath",
    "W": "w",
    "Wq": "wq",
    "Q": "q",
  },
  "cursor_blink": false,
  "relative_line_numbers": "enabled",
  "scroll_beyond_last_line": "off",
  "vertical_scroll_margin": 0,
  "gutter": {
    "line_numbers": false,
  },
  "file_types": {
    "Dockerfile": ["Dockerfile*"],
    "Shell Script": [".env*"],
  },
}
