#!/usr/bin/env bash
set -euo pipefail

if [[ $# -eq 0 ]]; then
  echo "usage: mux <command> [args...]" >&2
  exit 1
fi

slug() {
  printf '%s' "$1" | tr ' /' '__' | tr -cd '[:alnum:]_.-'
}

parent="$(slug "$(basename "$(dirname "$PWD")")")"
repo="$(slug "$(basename "$PWD")")"
session="${parent}__${repo}"
window="$(slug "$*")"

if tmux has-session -t "$session" 2>/dev/null; then
  tmux new-window -t "$session" -n "$window" "$*"
  exec tmux attach -t "$session"
fi

exec tmux new-session -s "$session" -n "$window" "$*"
