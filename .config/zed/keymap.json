// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      "cmd-shift-s": ["task::Spawn", { "task_name": "zed-sessioniser" }],
      "cmd-p": [
        "task::Spawn",
        { "task_name": "files", "reveal_target": "center" },
      ],
      "\\ w d": [
        "task::Spawn",
        { "task_name": "marlin-doctor", "reveal_target": "center" },
      ],
      "\\ w s": [
        "task::Spawn",
        { "task_name": "marlin-spends", "reveal_target": "center" },
      ],
      "\\ w v": [
        "task::Spawn",
        { "task_name": "vpn", "reveal_target": "center" },
      ],
    },
  },
  {
    "bindings": {
      // navigation
      "cmd-shift-h": "workspace::ActivatePaneLeft",
      "cmd-shift-l": "workspace::ActivatePaneRight",
      "cmd-shift-k": "workspace::ActivatePaneUp",
      "cmd-shift-j": "workspace::ActivatePaneDown",

      "cmd-k cmd-enter": "workspace::ToggleZoom",
      "shift-escape": null,
      "cmd-shift-down": "vim::ResizePaneDown",
      "cmd-shift-up": "vim::ResizePaneUp",
      "cmd-shift-left": "vim::ResizePaneLeft",
      "cmd-shift-right": "vim::ResizePaneRight",

      // Tmux and vim style key bindings
      "cmd-shift-e": "project_panel::Toggle",
      "cmd-shift-g": "git_panel::Toggle",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "cmd-k space": "terminal::ToggleViMode",
      "cmd-k cmd-k": ["terminal::SendKeystroke", "cmd-l"],
      "shift-enter": ["terminal::SendText", "\u001b\r"],
    },
  },
  {
    // Vim normal and visual mode
    "context": "Editor && (vim_mode == normal || vim_mode == visual) && !VimWaiting && !menu",
    "bindings": {
      "g E": "diagnostics::Deploy",
      "W": "vim::NextSubwordStart",
      "B": "vim::PreviousSubwordStart",
      "E": "vim::NextSubwordEnd",
      "s": "vim::PushSneak",
      "S": "vim::PushSneakBackward",
    },
  },
  {
    "context": "Workspace",
    "unbind": {
      "cmd-shift-t": "pane::ReopenClosedItem",
    },
  },
  {
    "bindings": {
      "cmd-k cmd-k": "workspace::NewCenterTerminal",
      "cmd-k cmd-p": "pane::TogglePinTab",
    },
  },
  {
    "bindings": {
      "cmd-shift-t": "terminal_panel::Toggle",
    },
  },
]
